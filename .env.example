# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=CEREP
APP_ENV=development
SECRET_KEY=changeme-super-secret-key-32chars!!

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./cerep.db

# ── LLM Stage 1 — vLLM (Constrained Decoding) ────────────────────────────────
VLLM_BASE_URL=http://localhost:8001
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_TEMPERATURE=0.1
VLLM_MAX_TOKENS=512
VLLM_TIMEOUT=120

# ── LLM Stage 2 — Fusion Decoder ─────────────────────────────────────────────
FUSION_PROVIDER=openai
FUSION_BASE_URL=https://api.openai.com/v1
FUSION_MODEL=gpt-4.1
FUSION_API_KEY=
FUSION_TEMPERATURE=0.3
FUSION_MAX_TOKENS=1024
FUSION_TIMEOUT=180

# ── Legacy Ollama (fallback) ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3:8b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=256
LLM_TIMEOUT=120

# ── Knowledge Graph ───────────────────────────────────────────────────────────
KG_MODE=networkx
KG_BUILD_MODE=adapters
KG_CACHE_PATH=backend/graph/graph_cache.json
KG_MAX_HOPS=4

# ── Neo4j (when KG_MODE=neo4j) ───────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
